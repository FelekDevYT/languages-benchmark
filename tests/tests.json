{
  "languages": [
    {
      "name": "Java",
      "install": "sudo apt install -y openjdk-21-jdk",
      "folder": "java",
      "compile": [
        "javac $FMain.java -d $BF"
      ],
      "run": [
        "java -cp $BF Main"
      ]
    },
    {
      "name": "Python",
      "install": "sudo apt install -y python3",
      "folder": "python",
      "compile": [],
      "run": [
        "python $Fmain.py"
      ]
    },
    {
      "name": "Rust",
      "install": "sudo apt install -y rustc",
      "folder": "rust",
      "compile": [
        "rustc $Fmain.rs -C opt-level=3 -C lto=fat -C codegen-units=1 -C panic=abort -C target-cpu=native -o $BFmain"
      ],
      "run": [
        "./$BFmain"
      ]
    },
    {
      "name": "D",
      "install": "sudo apt install -y gdc",
      "folder": "d",
      "compile": [
        "gdc $Fmain.d -O3 -march=native -flto -fomit-frame-pointer -funroll-loops -pipe -o $BFmain"
      ],
      "run": [
        "./$BFmain"
      ]
    },
    {
      "name": "C",
      "install": "sudo apt install -y gcc",
      "folder": "c",
      "compile": [
        "gdc $Fmain.d -O3 -march=native -flto -fomit-frame-pointer -funroll-loops -frelease -fbounds-check=off -pipe -o $BFmain"
      ],
      "run": [
        "./$BFmain"
      ]
    },{
      "name": "C++",
      "install": "sudo apt install -y g++",
      "folder": "cpp",
      "compile": [
        "g++ $Fmain.cpp -O3 -march=native -flto -fomit-frame-pointer -funroll-loops -ffast-math -fno-stack-protector -pipe -std=c++17 -o $BFmain"
      ],
      "run": [
        "./$BFmain"
      ]
    }
  ]
}